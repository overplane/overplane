#!/usr/bin/env bash
set -euo pipefail

want="$(awk '$1 == "go" { split($2, p, "."); print p[1] "." p[2] }' go.mod)"
have="$(go env GOVERSION | sed -E 's/^go([0-9]+\.[0-9]+).*/\1/')"
if [[ "${want}" != "${have}" ]]; then
  echo "Go minor version mismatch: go.mod requires ${want}, local toolchain is ${have}" >&2
  exit 1
fi
